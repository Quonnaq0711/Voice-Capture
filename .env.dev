# Development Environment Configuration
# This configuration is for local development and avoids all container ports

SECRET_KEY=dev-secret-key-change-in-production
ENVIRONMENT=development
NODE_ENV=development

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated)
# Development environment allows local development ports
CORS_ALLOWED_ORIGINS=http://localhost:1000,http://localhost:3000,http://127.0.0.1:1000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000

# ============================================
# PORT CONFIGURATION
# ============================================
# Backend Services (avoiding container ports 8000-8002)
# Note: Port 6000 is blocked by Chrome browser (X11 unsafe port). Using 5000 instead.
BACKEND_PORT=5000
PA_PORT=6001
CAREER_PORT=6002

# Frontend (avoiding container port 3000)
FRONTEND_PORT=1000

# Ollama Instances (avoiding container ports 11434-11435)
OLLAMA1_PORT=12434
OLLAMA2_PORT=12435

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Use SQLite for local development
DB_TYPE=sqlite
# DATABASE_PATH is relative to project root (backend/db/app.db)
# The application will automatically construct the full path
DATABASE_PATH=backend/db/app.db

# PostgreSQL config (not used in dev, but kept for reference)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=idii-dev
DB_HOST=localhost
DB_PORT=5432

# ============================================
# FRONTEND URLS
# ============================================
# Pointing to dev ports (5000, 6001-6002)
REACT_APP_BACKEND_URL=http://localhost:5000
REACT_APP_PA_URL=http://localhost:6001
REACT_APP_CAREER_URL=http://localhost:6002
REACT_APP_ENVIRONMENT=development

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_MODEL=gemma3:latest
OLLAMA_ORIGINS=*

# Personal Assistant Ollama on Port 12434
PA_OLLAMA_URL=http://localhost:12434
DASHBOARD_OLLAMA_URL=http://localhost:12434
PA_LLM_MODEL=gemma3:latest
PA_LLM_BASE_URL=http://localhost:12434
PA_LLM_TEMPERATURE=0.7
PA_LLM_MAX_TOKENS=2048

# Career Agent Ollama on Port 12435
CAREER_OLLAMA_URL=http://localhost:12435
CAREER_LLM_MODEL=gemma3:latest
CAREER_LLM_BASE_URL=http://localhost:12435
CAREER_LLM_TEMPERATURE=0.7
CAREER_LLM_MAX_TOKENS=2048

# Career Agent API URL
CAREER_AGENT_URL=http://localhost:6002

# ============================================
# LLM PROVIDER SELECTION
# ============================================
# Options: ollama | vllm
# Default: ollama (for local development)
LLM_PROVIDER=vllm

# ============================================
# vLLM CONFIGURATION (Development Mode)
# ============================================
# Enable vLLM by setting LLM_PROVIDER=vllm
# Model Selection (can switch to any HuggingFace model)
# Current: Google Gemma 3 4B - Multimodal (image-text-to-text) with excellent English capability
VLLM_MODEL=google/gemma-3-4b-it

# HuggingFace Authentication (required for gated models like Gemma 3)
# Get your token from: https://huggingface.co/settings/tokens
# IMPORTANT: Replace 'your_hf_token_here' with your actual token
# HF_TOKEN=your_hf_token_here
HF_TOKEN=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
# Alternative model examples:
# VLLM_MODEL=google/gemma-3-1b-it              # Faster, smaller (1B)
# VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct          # Better Chinese support (3B)
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct          # Balanced Chinese/English (7B)
# VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3 # Excellent English (7B)
# VLLM_MODEL=google/gemma-2-9b-it              # Strong English, no multimodal (9B)

# API Configuration
VLLM_API_BASE=http://localhost:8888/v1
VLLM_TEMPERATURE=0.7
# Increased for full analysis + summary generation
VLLM_MAX_TOKENS=4096  
VLLM_TOP_P=0.9
VLLM_FREQUENCY_PENALTY=0.0
VLLM_PRESENCE_PENALTY=0.0

# vLLM Server Startup Configuration (for startup script)
# Development configuration for NVIDIA L4 (23GB) with Staging Ollama running:
# - 0.5 GPU utilization (conservative, shares GPU with staging Ollama containers)
# - 4096 context length (optimal for most conversations, 10-15 rounds)
# - 4096 batched tokens (balanced throughput)
# Concurrent capacity: ~20-30 users
VLLM_HOST=0.0.0.0
VLLM_PORT=8888
VLLM_GPU_MEMORY_UTILIZATION=0.85
# Qwen2.5-3B supports up to 32K, using 8K for better performance
VLLM_MAX_MODEL_LEN=8192  
VLLM_DTYPE=bfloat16
VLLM_TRUST_REMOTE_CODE=true
VLLM_TENSOR_PARALLEL_SIZE=1
# Match MAX_MODEL_LEN for consistent batching
VLLM_MAX_NUM_BATCHED_TOKENS=8192  

# Optional: Quantization (saves VRAM)
# VLLM_QUANTIZATION=awq

# Context Management and Token Optimization
# Sliding window: keep last N conversation turns (1 turn = user + assistant)
VLLM_MAX_HISTORY_TURNS=10
# Reserve tokens for response generation (prevents truncation)
VLLM_SAFETY_MARGIN=512

# ============================================
# EMAIL CONFIGURATION
# ============================================
MAILGUN_API_KEY=key-2952c74184bb22a9c607d6f246274bb3
MAILGUN_DOMAIN=sadaora.com
APP_NAME=Idii-Dev
FROM_EMAIL=postmaster@sadaora.com

SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=jumah@sadaora.com
SMTP_PASS=iUv3u.tKm#adXQJ#AA*tPNX~

# Internal API Key for service-to-service communication
INTERNAL_API_KEY=dev-internal-key-change-in-production
