# OLLAMA ENV
OLLAMA_MODEL=gemma3:latest
OLLAMA_BASE_URL=http://ollama-staging:11434
OLLAMA_ORIGINS=*
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_GPU_ENABLED=true

# Personal Assistant Ollama Configuration
DASHBOARD_OLLAMA_URL=http://ollama-staging:11434

# Career Agent Ollama Configuration
CAREER_OLLAMA_URL=http://ollama2-staging:11434

# Career Agent API URL (for recommendation service)
CAREER_AGENT_URL=http://idii-career-agent-staging:8002

# Personal Assistant API URL (for Career Agent notifications)
PA_NOTIFICATION_SERVICE_URL=http://idii-PA-staging:8001

# Internal API Key for service-to-service communication
INTERNAL_API_KEY=staging-internal-412a13de64f63d3e3840ee7c0ea5f2f3
# ============================================
# LLM PROVIDER SELECTION
# ============================================
# Options: ollama | vllm
# Recommended: vllm (for production high performance)
LLM_PROVIDER=vllm

# ============================================
# vLLM CONFIGURATION (Production Mode - L4 GPU 23GB)
# ============================================
# HuggingFace Token (required for gated models)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token_here

# Model Selection for L4 GPU (23GB VRAM)
# google/gemma-3-4b-it: 4B params, ~8GB VRAM, excellent for English
VLLM_MODEL=google/gemma-3-4b-it

# API Configuration (OpenAI-compatible endpoint)
VLLM_API_BASE=http://vllm-server:8888/v1
VLLM_TEMPERATURE=0.7
VLLM_MAX_TOKENS=4096
VLLM_TOP_P=0.9
VLLM_FREQUENCY_PENALTY=0.0
VLLM_PRESENCE_PENALTY=0.0

# vLLM Server Configuration (Optimized for L4 GPU 23GB)
# L4 Ada Lovelace (Compute 8.9) - excellent bfloat16 support
VLLM_HOST=0.0.0.0
VLLM_PORT=8888
# 4B model uses ~8GB, use 90% of 23GB = ~20GB for KV cache
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_MAX_MODEL_LEN=8192
VLLM_DTYPE=bfloat16
VLLM_TRUST_REMOTE_CODE=true
VLLM_TENSOR_PARALLEL_SIZE=1

# Performance Optimization (L4 with 4B model)
# Conservative: 64 concurrent sequences with 8K context
# Memory: 8GB model + ~12GB KV cache = 20GB (within 90% of 23GB)
VLLM_MAX_NUM_SEQS=64
# Batch tokens: 2x context length for better throughput
VLLM_MAX_NUM_BATCHED_TOKENS=16384

# Context Management
VLLM_MAX_HISTORY_TURNS=10
VLLM_SAFETY_MARGIN=512
