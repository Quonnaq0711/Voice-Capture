FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip install --no-cache-dir --upgrade pip

# Copy requirements
COPY backend/personal_assistant/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared backend modules
COPY backend/db/ /app/backend/db/
COPY backend/models/ /app/backend/models/
COPY backend/utils/ /app/backend/utils/
COPY backend/services/ /app/backend/services/
COPY backend/config/ /app/backend/config/
COPY backend/personal_assistant/ /app/backend/personal_assistant/

# Create __init__.py files for backend module
RUN touch /app/backend/__init__.py

# Copy PA main files to /app
COPY backend/personal_assistant/ /app/

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8001/api/chat/health || exit 1

EXPOSE 8001

# Optimized for 4-core CPU: 4 workers (limited by LLM processing, not CPU)
# For 8-core CPU, increase to 6-8 workers
CMD ["gunicorn", "main:app", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "--bind", "0.0.0.0:8001", "--timeout", "120", "--worker-connections", "1000"]
